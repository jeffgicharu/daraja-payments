# Get these from developer.safaricom.co.ke -> My Apps (sandbox)
DARAJA_CONSUMER_KEY=
DARAJA_CONSUMER_SECRET=
# Sandbox Lipa na M-Pesa passkey (from the Daraja docs/simulator page)
DARAJA_PASSKEY=
# Public URL for callbacks (ngrok/cloudflared tunnel during local dev)
DARAJA_CALLBACK_BASE_URL=
# API security (JWT issuance + validation). Secret must be >= 32 bytes.
API_JWT_SECRET=
API_CLIENT_ID=
API_CLIENT_SECRET=
